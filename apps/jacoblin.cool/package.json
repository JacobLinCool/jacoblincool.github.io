{
    "name": "jacoblin.cool",
    "private": true,
    "version": "0.0.1",
    "type": "module",
    "scripts": {
        "dev": "pnpm --filter @jacoblincool/agent build && firebase emulators:exec --ui 'vite dev'",
        "build": "pnpm --filter @jacoblincool/agent build && vite build",
        "preview": "pnpm --filter @jacoblincool/agent build && vite preview",
        "prepare": "svelte-kit sync || echo ''",
        "check": "pnpm --filter @jacoblincool/agent build && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
        "check:watch": "pnpm --filter @jacoblincool/agent build && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
        "lint": "eslint .",
        "test": "pnpm --filter @jacoblincool/agent build && vitest run",
        "test:watch": "vitest"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.2",
        "@eslint/js": "^10.0.1",
        "@inlang/paraglide-js": "^2.12.0",
        "@sveltejs/adapter-cloudflare": "^7.2.8",
        "@sveltejs/kit": "^2.52.0",
        "@sveltejs/vite-plugin-svelte": "^6.2.4",
        "@tailwindcss/typography": "^0.5.19",
        "@tailwindcss/vite": "^4.1.18",
        "@types/node": "^25.2.3",
        "daisyui": "^5.5.18",
        "eslint": "^10.0.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-svelte": "^3.15.0",
        "firebase-tools": "^15.6.0",
        "globals": "^17.3.0",
        "svelte": "^5.51.2",
        "svelte-check": "^4.4.0",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.55.0",
        "vite": "^7.3.1",
        "vite-plugin-devtools-json": "^1.0.0",
        "vitest": "^4.1.0"
    },
    "dependencies": {
        "@lucide/svelte": "^0.564.0",
        "@jacoblincool/agent": "workspace:*",
        "firebase": "^12.9.0",
        "fires2rest": "^0.3.0",
        "jose": "^6.1.3",
        "marked": "^17.0.4",
        "posthog-js": "^1.257.2",
        "posthog-node": "^4.12.1",
        "svelte-confetti": "^2.3.2"
    }
}
